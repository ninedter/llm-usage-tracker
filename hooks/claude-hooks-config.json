{
  "_comment": "Add these hooks to ~/.claude/settings.json. For local use no extra variables are needed — the hook auto-discovers the tracker on :3789 (Docker), :3000, and the Electron port file. For cloud/remote sessions, set MONITOR_URL instead.",

  "hooks_local": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_TYPE=PreToolUse /path/to/llm-usage-tracker/hooks/agent-monitor-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_TYPE=PostToolUse /path/to/llm-usage-tracker/hooks/agent-monitor-hook.sh"
          }
        ]
      }
    ]
  },

  "hooks_cloud": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_TYPE=PreToolUse MONITOR_URL=https://YOUR-TUNNEL.trycloudflare.com /path/to/llm-usage-tracker/hooks/agent-monitor-hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_TYPE=PostToolUse MONITOR_URL=https://YOUR-TUNNEL.trycloudflare.com /path/to/llm-usage-tracker/hooks/agent-monitor-hook.sh"
          }
        ]
      }
    ]
  }
}
